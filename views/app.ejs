<!DOCTYPE html>
<html>
  <head>
    <title>DIBSL Runtime Environment</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
    />
    <style>
      body {
        background-color: #121212;
        color: #e0e0e0;
        font-family: "Segoe UI", monospace;
      }
      .terminal {
        background: #000;
        border: 1px solid #333;
        padding: 20px;
        height: 400px;
        overflow-y: auto;
        font-family: "Courier New", courier;
      }
      .log-info {
        color: #888;
      }
      .log-success {
        color: #0f0;
      }
      .log-error {
        color: #f00;
      }
      .log-warn {
        color: #ffc107;
      }
      .secret-content {
        filter: blur(5px);
        transition: filter 0.5s;
      }
      .unlocked {
        filter: blur(0);
        border: 2px solid #0f0;
      }
    </style>
  </head>
  <body class="container py-5">
    <div class="row">
      <div class="col-md-4">
        <h3>🔒 DIBSL Runtime</h3>
        <p class="small text-muted">Client-Side Ephemeral Vault</p>

        <div class="card bg-dark text-light mb-3">
          <div class="card-body">
            <label>Wallet Identity</label>
            <div id="userAddress" class="text-info mb-3">Not Connected</div>

            <label>License Token ID</label>
            <input
              type="number"
              id="tokenIdInput"
              class="form-control mb-3"
              placeholder="e.g. 1"
              value="1"
            />

            <button id="connectBtn" class="btn btn-primary w-100 mb-2">
              1. Connect Wallet
            </button>
            <button id="launchBtn" class="btn btn-success w-100" disabled>
              2. Launch Software
            </button>
          </div>
        </div>

        <div class="alert alert-secondary">
          <strong>Status:</strong> <span id="statusText">Idle</span>
        </div>
      </div>

      <div class="col-md-8">
        <div class="card bg-dark text-light mb-4">
          <div class="card-header border-secondary">
            Protected Module (AES-256 Encrypted)
          </div>
          <div class="card-body text-center">
            <div
              id="protectedContent"
              class="secret-content p-5 bg-secondary text-white rounded"
            >
              <h3>TOP SECRET ALGORITHM</h3>
              <p>If you can read this, the Ephemeral Key was valid.</p>
              <div id="secretData" style="display: none">
                DATA: { "core_logic": "RUNNING", "algo_id": "X99" }
              </div>
            </div>
          </div>
        </div>

        <div class="terminal" id="console">
          <div>_ DIBSL Secure Loader v1.0</div>
          <div>_ Waiting for authorization...</div>
        </div>
      </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/ethers/6.7.0/ethers.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/crypto-js/4.1.1/crypto-js.min.js"></script>
    <script src="/js/client.js"></script>
  </body>
</html>
