<!DOCTYPE html>
<html>
  <head>
    <title>DIBSL Vendor Dashboard</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
    />
    <style>
      body {
        background-color: #f8f9fa;
      }
      .card {
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
      }
      .status-box {
        font-family: monospace;
        background: #222;
        color: #0f0;
        padding: 10px;
        border-radius: 5px;
      }
    </style>
  </head>
  <body class="container py-5">
    <div class="row mb-4">
      <div class="col">
        <h1>🛡️ DIBSL Vendor Authority</h1>
        <p class="text-muted">
          Decentralized Identity-Bound Software Licensing
        </p>
      </div>
      <div class="col-auto">
        <button id="connectBtn" class="btn btn-warning">
          Connect MetaMask
        </button>
      </div>
    </div>

    <div class="card mb-4">
      <div class="card-body">
        <h5>System Status</h5>
        <p>
          <strong>Contract Address:</strong>
          <span id="contractAddr"><%= contractAddress %></span>
        </p>
        <p>
          <strong>Your Admin Address:</strong>
          <span id="adminAddr">Not Connected</span>
        </p>
      </div>
    </div>

    <div class="row">
      <div class="col-md-6">
        <div class="card h-100">
          <div class="card-header bg-primary text-white">
            Issue New License (Mint SBT)
          </div>
          <div class="card-body">
            <form id="mintForm">
              <div class="mb-3">
                <label>Customer Wallet Address</label>
                <input
                  type="text"
                  id="recipient"
                  class="form-control"
                  placeholder="0x..."
                  required
                />
              </div>
              <div class="mb-3">
                <label>Product ID</label>
                <input
                  type="number"
                  id="productId"
                  class="form-control"
                  value="101"
                  required
                />
              </div>
              <div class="mb-3">
                <label>License Tier (0=Basic, 1=Pro, 2=Ent)</label>
                <select id="tier" class="form-select">
                  <option value="0">Basic</option>
                  <option value="1">Pro (Recommended)</option>
                  <option value="2">Enterprise</option>
                </select>
              </div>
              <div class="mb-3">
                <label>Duration (Days)</label>
                <input
                  type="number"
                  id="days"
                  class="form-control"
                  value="365"
                />
              </div>
              <button type="submit" class="btn btn-success w-100">
                Mint License SBT
              </button>
            </form>
          </div>
        </div>
      </div>

      <div class="col-md-6">
        <div class="card h-100">
          <div class="card-header bg-dark text-white">Transaction Logs</div>
          <div class="card-body">
            <div
              id="logs"
              class="status-box"
              style="height: 300px; overflow-y: auto"
            >
              <div>> Ready to issue licenses...</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="text-center mt-5">
      <a href="/app" class="btn btn-outline-secondary"
        >➡️ Switch to User Client View</a
      >
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/ethers/6.7.0/ethers.umd.min.js"></script>
    <script src="/js/vendor.js"></script>
  </body>
</html>
